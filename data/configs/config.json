{
  "log": {
    "level": "DEBUG",
    "console": {
      "enabled": false,
      "level": "DEBUG",
      "color": true
    },
    "file": {
      "enabled": true,
      "level": "DEBUG",
      "path": "logs",
      "rotation": {
        "max_size_mb": 100,
        "retention_days": 30,
        "max_total_size_mb": 1024,
        "warning_separate": true,
        "by_date": true,
        "by_size": true
      }
    },
    "performance": {
      "async_enabled": true,
      "async_queue_size": 1000
    },
    "console_window": true,
    "format": {
      "file_json": false
    }
  },
  "encryption": {
    "master_key_file": "data/secrets/master.key"
  },
  "deepseek": {
    "module_1": {
      "base_url": "https://api.deepseek.com",
      "timeout": 60,
      "max_retries": 3,
      "rate_limit_per_second": 5.0,
      "save_conversations_dir": "data/conversations",
      "save_sensitive": false,
      "default_model": "deepseek-v4-falsh",
      "default_temperature": 0.8,
      "default_max_tokens": 4096,
      "default_top_p": 1.0,
      "default_reasoning_effort": "high",
      "thinking_enabled": true,
      "models_cache_ttl_seconds": 3600
    }
  },
  "api_keys_file": "data/secrets/api_keys.json"
}